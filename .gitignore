# =========================================
# Unreal Engine 项目忽略规则（Mvpv4TestCodex）
# 说明：保留源码/文档/配置，忽略构建产物与本地缓存
# =========================================

# UE 构建产物与中间文件
Binaries/
Intermediate/
Saved/
DerivedDataCache/
Build/

# 插件构建产物（双保险）
Plugins/*/Binaries/
Plugins/*/Intermediate/

# AgentBridge 插件本地产物
Plugins/AgentBridge/Binaries/
Plugins/AgentBridge/Intermediate/
Plugins/AgentBridge/Saved/
Plugins/AgentBridge/DerivedDataCache/
Plugins/AgentBridge/Scripts/bridge/__pycache__/
Plugins/AgentBridge/Scripts/orchestrator/__pycache__/
Plugins/AgentBridge/**/__pycache__/
Plugins/AgentBridge/**/*.pyc
Plugins/AgentBridge/**/*.pyo
Plugins/AgentBridge/Gauntlet/obj/
Plugins/AgentBridge/Gauntlet/bin/
Plugins/AgentBridge/reports/
Plugins/AgentBridge/AgentBridgeTests/Binaries/
Plugins/AgentBridge/AgentBridgeTests/Intermediate/

# 本地报告与证据目录（如需保留可删除此行）
reports/

# IDE 与本地工程文件
.vscode/
*.code-workspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Visual Studio / Rider 用户文件
.vs/
.idea/
*.user
*.userprefs
*.csproj.user

# 日志与临时文件
*.log
*.tmp
*.temp
__pycache__/
*.pyc
Gauntlet/obj/

# 系统文件
.DS_Store
Thumbs.db

# AgentBridge 插件源码/文档保护
!Plugins/AgentBridge/.gitignore
!Plugins/AgentBridge/AGENTS.md
!Plugins/AgentBridge/README.md
!Plugins/AgentBridge/AgentBridge.uplugin
!Plugins/AgentBridge/Docs/**/*.md
!Plugins/AgentBridge/Roadmap/**/*.md
!Plugins/AgentBridge/Schemas/**/*.json
!Plugins/AgentBridge/Scripts/**/*.py
!Plugins/AgentBridge/Scripts/**/*.ps1
!Plugins/AgentBridge/Source/**/*.h
!Plugins/AgentBridge/Source/**/*.cpp
!Plugins/AgentBridge/Specs/**/*.md
!Plugins/AgentBridge/Specs/**/*.yaml
!Plugins/AgentBridge/Gauntlet/**/*.cs
!Plugins/AgentBridge/Gauntlet/**/*.csproj
!Plugins/AgentBridge/AgentBridgeTests/.gitignore
!Plugins/AgentBridge/AgentBridgeTests/**/*.uplugin
!Plugins/AgentBridge/AgentBridgeTests/**/*.Build.cs
!Plugins/AgentBridge/AgentBridgeTests/**/*.h
!Plugins/AgentBridge/AgentBridgeTests/**/*.cpp
