{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpecPatchContractModel",
  "type": "object",
  "required": ["contract_id", "contract_kind", "target_spec_family", "data"],
  "properties": {
    "contract_id": {"type": "string"},
    "contract_kind": {"type": "string", "const": "patch"},
    "target_spec_family": {
      "type": "array",
      "items": {"type": "string"}
    },
    "data": {
      "type": "object",
      "required": ["target_spec", "allowed_operations", "validation_requirements"],
      "properties": {
        "target_spec": {"type": "string"},
        "allowed_operations": {
          "type": "array",
          "items": {"type": "string"}
        },
        "protected_fields": {
          "type": "array",
          "items": {"type": "string"}
        },
        "validation_requirements": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
