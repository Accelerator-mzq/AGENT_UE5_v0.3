{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MigrationContractModel",
  "type": "object",
  "required": ["contract_id", "contract_kind", "target_spec_family", "data"],
  "properties": {
    "contract_id": {"type": "string"},
    "contract_kind": {"type": "string", "const": "migration"},
    "target_spec_family": {
      "type": "array",
      "items": {"type": "string"}
    },
    "data": {
      "type": "object",
      "required": ["migration_scope", "preconditions", "rollback_expectations"],
      "properties": {
        "migration_scope": {"type": "string"},
        "preconditions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "rollback_expectations": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
