{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BoardgameStaticSpec",
  "type": "object",
  "required": ["spec_id", "version", "data"],
  "properties": {
    "spec_id": { "type": "string", "const": "BoardgameStaticSpec" },
    "version": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["board", "piece_catalog", "preview_policy", "rules"],
      "properties": {
        "board": { "type": "object" },
        "piece_catalog": { "type": "array", "items": { "type": "object" } },
        "preview_policy": {
          "type": "object",
          "required": ["source", "generate_preview", "piece_counts"],
          "properties": {
            "source": { "type": "string" },
            "generate_preview": { "type": "boolean" },
            "piece_counts": { "type": "object" }
          }
        },
        "rules": { "type": "object" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
