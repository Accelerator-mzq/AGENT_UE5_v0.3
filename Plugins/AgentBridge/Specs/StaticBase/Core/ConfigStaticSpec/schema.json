{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConfigStaticSpec",
  "type": "object",
  "required": ["spec_id", "version", "data"],
  "properties": {
    "spec_id": { "type": "string", "const": "ConfigStaticSpec" },
    "version": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["target_engine_version", "target_platforms"],
      "properties": {
        "target_engine_version": { "type": "string" },
        "target_platforms": { "type": "array", "items": { "type": "string" } },
        "editor_constraints": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
