{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorldBuildStaticSpec",
  "type": "object",
  "required": ["spec_id", "version", "data"],
  "properties": {
    "spec_id": { "type": "string", "const": "WorldBuildStaticSpec" },
    "version": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["board", "actor_defaults"],
      "properties": {
        "board": {
          "type": "object",
          "required": ["grid_size", "cell_size_cm", "total_size_cm", "location"],
          "properties": {
            "board_type": { "type": "string" },
            "grid_size": {
              "type": "array",
              "items": { "type": "integer" },
              "minItems": 2,
              "maxItems": 2
            },
            "cell_size_cm": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "total_size_cm": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "location": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 3,
              "maxItems": 3
            },
            "material": { "type": "string" }
          }
        },
        "actor_defaults": {
          "type": "object",
          "required": ["actor_class", "board_scale_z"],
          "properties": {
            "actor_class": { "type": "string" },
            "board_scale_z": { "type": "number" }
          }
        },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
